{
  "name": "xspec",
  "version": "0.1.2",
  "description": "Orchestrate executable-spec workflows (write, verify, debug, implement) from host Claude Code via a Dockerized runtime. v1 backend: Quint.",
  "mcpServers": {
    "quint-kb": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "quint-runtime",
        "node",
        "/home/dev/mcp-servers/kb/dist/server.js"
      ]
    },
    "quint-lsp": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "quint-runtime",
        "mcp-language-server",
        "--workspace",
        "/workspace",
        "--lsp",
        "quint-language-server",
        "--",
        "--stdio"
      ]
    }
  }
}
